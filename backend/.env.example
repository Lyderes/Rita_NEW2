APP_NAME=RITA Backend
DEBUG=false
BACKEND_HOST=localhost
BACKEND_PORT=8080
# Base de datos canónica: Postgres (Docker Compose, puerto 5434 mapeado al host)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5434/rita

# MQTT Broker (Docker Compose, puerto 1883)
MQTT_BROKER=localhost
MQTT_PORT=1883

JWT_SECRET=change-me-local-dev-secret-key-2026
# Legacy alias still supported:
# SECRET_KEY=change-me-local-dev-secret-key-2026
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5180,http://127.0.0.1:5180,http://localhost:5190,http://127.0.0.1:5190
FRONTEND_USERNAME=admin
FRONTEND_PASSWORD=admin123
# Notification Providers
FCM_CREDENTIALS_PATH=./firebase-adminsdk.json
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# GDPR & Data Retention
ENABLE_DATA_RETENTION=false
DATA_RETENTION_EVENTS_DAYS=90
DATA_RETENTION_NOTIFICATION_JOBS_DAYS=30
DATA_RETENTION_CLOSED_ALERTS_DAYS=180

# Backups
DB_BACKUP_DIR=./backups